{
  "name": "lumina-cards",
  "version": "1.0.0",
  "description": "Premium Home Assistant card collection with glassmorphism design, SVG arc indication rings, and atmospheric dark theme",
  "type": "module",
  "main": "dist/lumina-cards.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c --watch",
    "start": "rollup -c --watch --environment SERVE"
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "custom-card",
    "hacs",
    "smart-home",
    "glassmorphism",
    "lumina"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "custom-card-helpers": "^1.9.0",
    "home-assistant-js-websocket": "^9.4.0",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "rollup": "^4.24.0",
    "rollup-plugin-serve": "^3.0.0",
    "tslib": "^2.8.0",
    "typescript": "^5.6.0"
  }
}
